{
	"name": "obsidian-rechner-plugin",
	"version": "0.7.0",
	"description": "Obsidian frontend for WebAssembly based calculator engines",
	"main": "main.js",
	"scripts": {
		"wasm": "RUSTFLAGS='--cfg getrandom_backend=\"wasm_js\"' wasm-pack build --target=web ./kernels/numbat-kernel --release",
		"dev": "NODE_ENV=development vite build --mode development --watch",
		"build": "tsc -noEmit -skipLibCheck && vite build --mode production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"tag": "node tag.mjs",
		"lint": "eslint --ext .js,.ts,.json src && stylelint styles.css && npx npm-package-json-lint .",
		"prepare-lezer": "lezer-generator src/numbat-lang/numbat.grammar -o src/numbat-lang/NumbatParser.js"
	},
	"type": "module",
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@lezer/generator": "^1.8.0",
		"@types/node": "^20.19.39",
		"@vitejs/devtools": "^0.1.13",
		"builtin-modules": "3.3.0",
		"eslint": "9.39.2",
		"eslint-plugin-obsidianmd": "latest",
		"eslint-plugin-promise": "^7.2.1",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "8.58.1",
		"vite-plugin-inspect": "12.0.0-beta.1",
		"vite-plugin-wasm": "^3.6.0"
	},
	"dependencies": {
		"@codemirror/autocomplete": "^6.20.1",
		"@codemirror/language": "^6.12.3",
		"@lezer/highlight": "^1.2.3",
		"@lezer/lr": "^1.4.8",
		"@tailwindcss/postcss": "^4.2.2",
		"numbat-kernel": "link:kernels/numbat-kernel/pkg",
		"tailwindcss": "^4.2.2",
		"vite": "^7.3.2"
	},
	"peerDependencies": {
		"@codemirror/state": "6.5.0",
		"@codemirror/view": "6.38.6"
	}
}
